---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const guides = await getCollection('guide');
const masterGuide = guides.find(e => e.id === 'section-75-complete-guide');
if (!masterGuide) throw new Error('Master guide content entry not found');

const { Content } = await render(masterGuide);
const { title, description, disclaimer, updatedAt, publishedAt } = masterGuide.data;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Does the full purchase price need to be on the credit card?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Section 75 applies as long as the total purchase price was more than £100 and no more than £30,000, and at least £1 was paid on your credit card. If you paid a £50 deposit on a £1,500 sofa using your credit card and the rest by bank transfer, Section 75 applies to the full £1,500."
      }
    },
    {
      "@type": "Question",
      "name": "Does Section 75 cover debit cards?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Section 75 applies only to regulated consumer credit agreements. Debit cards are not credit agreements. If you paid by debit card, the alternative is chargeback, which is processed under card scheme rules rather than statute and has a much shorter time limit."
      }
    },
    {
      "@type": "Question",
      "name": "Does Section 75 cover purchases made abroad?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The House of Lords confirmed in Office of Fair Trading v Lloyds TSB Bank plc [2007] UKHL 48 that Section 75 applies to overseas transactions made on a UK credit card. If you booked a foreign holiday, bought goods from an overseas retailer, or paid for a service outside the UK using your UK credit card, Section 75 applies."
      }
    },
    {
      "@type": "Question",
      "name": "What if the retailer has gone into administration?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Administration or liquidation is one of the most common Section 75 scenarios, and one of the clearest. The company's inability to fulfil its obligations constitutes a breach of contract. Your credit card provider is jointly liable. You do not need to wait for the administration to conclude before making your claim."
      }
    },
    {
      "@type": "Question",
      "name": "Can I claim if I paid by credit card through a buy now, pay later scheme?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on the scheme. Some buy now, pay later products are regulated consumer credit agreements and Section 75 applies. Others are not regulated in the same way and fall outside the Act. Check whether your BNPL provider is authorised by the FCA as a consumer credit lender."
      }
    },
    {
      "@type": "Question",
      "name": "What if I paid via PayPal using my credit card?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Section 75 is less reliable for credit card payments made through PayPal because PayPal is the legal counterparty to the transaction, not the underlying merchant. PayPal has its own buyer protection programme. The Section 75 position for PayPal transactions is genuinely uncertain, and the Financial Ombudsman Service has reached different conclusions in different cases."
      }
    },
    {
      "@type": "Question",
      "name": "Does Section 75 cover store cards?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It can. If a store card is issued under a regulated consumer credit agreement, Section 75 applies in the same way as for a standard credit card. The purchase price thresholds and other conditions are the same."
      }
    },
    {
      "@type": "Question",
      "name": "Can I make a Section 75 claim if I have already received a partial refund?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Your claim is for your net loss: the amount you paid minus any amount already refunded to you. If you received a partial refund from the retailer or administrator before making your Section 75 claim, state the amounts clearly in your letter and claim only the outstanding balance."
      }
    },
    {
      "@type": "Question",
      "name": "Will making a Section 75 claim affect my credit score?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Making a Section 75 claim is a consumer rights process, not a credit application. It does not affect your credit score. There is no mechanism by which a Section 75 claim causes a mark on your credit file."
      }
    },
    {
      "@type": "Question",
      "name": "How much does it cost to make a Section 75 claim?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nothing. Making a claim directly to your card provider costs nothing. Escalating to the Financial Ombudsman Service costs nothing. You do not need to use a claims management company or a solicitor for a standard Section 75 claim."
      }
    }
  ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": publishedAt.toISOString().split('T')[0],
  "dateModified": updatedAt.toISOString().split('T')[0],
  "publisher": {
    "@type": "Organization",
    "name": "Section 75 Claim Helper",
    "url": "https://section75help.co.uk"
  }
};

const siteBase  = Astro.site ?? new URL('https://section75help.co.uk');
const pageURL   = new URL(Astro.url.pathname, siteBase).href;
const siteURL   = siteBase.href;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",               "item": siteURL },
    { "@type": "ListItem", "position": 2, "name": "Section 75 Guide",   "item": pageURL },
  ],
};

const sidebarLinks = [
  { href: '#what-section-75-actually-says',                                        label: 'What Section 75 says'        },
  { href: '#who-can-make-a-section-75-claim',                                      label: 'Who can claim'               },
  { href: '#what-counts-as-a-breach-of-contract',                                  label: 'Grounds for a claim'         },
  { href: '#the-three-party-structure-when-section-75-does-and-does-not-apply',    label: 'PayPal and intermediaries'   },
  { href: '#how-to-make-a-section-75-claim-step-by-step',                          label: 'Step-by-step claim'          },
  { href: '#what-evidence-to-gather',                                               label: 'Evidence to gather'          },
  { href: '#how-long-a-section-75-claim-takes',                                    label: 'How long it takes'           },
  { href: '#what-to-do-if-the-bank-rejects-your-claim',                            label: 'If the bank refuses'         },
  { href: '#frequently-asked-questions',                                            label: 'FAQs'                        },
];
---

<BaseLayout {title} {description} {disclaimer} ogType="article">
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <div class="lg:grid lg:grid-cols-[1fr_196px] lg:gap-10 lg:items-start">

    <!-- ── Main content column ──────────────────────────────────────────────── -->
    <div class="min-w-0">
      <article class="prose prose-gray max-w-none">
        <h1>{title}</h1>
        <Content />
      </article>

      <p class="mt-8 text-xs text-gray-400">
        Last updated: {updatedAt.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
      </p>

      <div class="mt-10 rounded-lg border p-6" style="border-color: #1e3a5f; background-color: #f0f4f8;">
        <h2 class="text-base font-semibold text-gray-900 mb-2">Ready to make your claim?</h2>
        <p class="text-sm text-gray-700 mb-4">
          The claim pack includes template letters with the correct legal citations, an evidence checklist, and rejection rebuttals for the most common bank responses. One plain-English PDF workbook, £6.99.
        </p>
        <a href="/claim-pack/" class="btn-primary">Get the template letters — £6.99</a>
      </div>
    </div>

    <!-- ── Sticky sidebar (desktop only) ────────────────────────────────────── -->
    <aside class="hidden lg:block" aria-label="Page navigation">
      <div class="sticky top-8">
        <nav class="rounded-lg bg-white shadow-sm ring-1 ring-gray-200/60 p-5">
          <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-4">In this guide</p>
          <ul class="space-y-2.5 text-sm">
            {sidebarLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  data-sidebar-link={href.slice(1)}
                  class="block text-gray-600 hover:text-gray-900 transition-colors leading-snug"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
          <div class="mt-6 pt-5 border-t border-gray-200">
            <a
              href="/claim-pack/"
              class="block text-center rounded py-2.5 text-xs font-bold text-white transition-opacity hover:opacity-90"
              style="background-color: #1e3a5f;"
            >
              Get the claim pack — £6.99
            </a>
          </div>
        </nav>
      </div>
    </aside>

  </div>
</BaseLayout>

<script>
  // Scroll-spy: highlight active section in sidebar nav
  const sections = Array.from(document.querySelectorAll('article h2[id]')) as HTMLElement[];
  const navLinks = Array.from(document.querySelectorAll('[data-sidebar-link]')) as HTMLElement[];

  if (sections.length && navLinks.length) {
    const activate = (id: string) => {
      navLinks.forEach(link => {
        const isActive = link.dataset.sidebarLink === id;
        link.classList.toggle('font-semibold', isActive);
        link.classList.toggle('text-gray-900', isActive);
        link.classList.toggle('text-gray-600', !isActive);
      });
    };

    const observer = new IntersectionObserver(
      entries => {
        const visible = entries.filter(e => e.isIntersecting);
        if (visible.length) activate(visible[0].target.id);
      },
      { rootMargin: '-10% 0% -80% 0%', threshold: 0 }
    );

    sections.forEach(s => observer.observe(s));
  }
</script>
