---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guide');
  return guides
    .filter(entry => entry.id !== 'section-75-complete-guide')
    .map(entry => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, disclaimer, updatedAt } = entry.data;
---

<BaseLayout {title} {description} {disclaimer}>
  <article class="prose prose-gray max-w-none">
    <Content />
  </article>
  <p class="mt-8 text-xs text-gray-400">
    Last updated: {updatedAt.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
  </p>

  <div class="mt-10 rounded-lg border p-6" style="border-color: #1e3a5f; background-color: #f0f4f8;">
    <h2 class="text-base font-semibold text-gray-900 mb-2">Ready to make your claim?</h2>
    <p class="text-sm text-gray-700 mb-4">
      The claim pack includes template letters with the correct legal citations, an evidence checklist, and rejection rebuttals for the most common bank responses. One PDF, nine documents, £6.99.
    </p>
    <a href="/claim-pack/" class="btn-primary">Get the template letters — £6.99</a>
  </div>
</BaseLayout>
