---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const triggers = await getCollection('trigger');
  return triggers.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, disclaimer, noindex, publishedAt, updatedAt, companyName, administrationDate } = entry.data;

const siteBase  = Astro.site ?? new URL('https://section75help.co.uk');
const pageURL   = new URL(Astro.url.pathname, siteBase).href;
const siteURL   = siteBase.href;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",             "item": siteURL  },
    { "@type": "ListItem", "position": 2, "name": "Business failures", "item": siteURL  },
    { "@type": "ListItem", "position": 3, "name": companyName ?? title, "item": pageURL },
  ],
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": title,
  "description": description,
  "datePublished": publishedAt.toISOString().split('T')[0],
  "dateModified":  updatedAt.toISOString().split('T')[0],
  "publisher": {
    "@type": "Organization",
    "name": "Section 75 Claim Helper",
    "url": siteURL,
  },
};
---

<BaseLayout {title} {description} {disclaimer} {noindex} ogType="article">
  <Fragment slot="head">
    {!noindex && (
      <>
        <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
        <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
      </>
    )}
  </Fragment>

  {noindex ? (
    <div class="mb-6 rounded border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
      <strong>Draft page.</strong> This page is not indexed and is not linked from the site navigation. It will be updated with verified details before publication.
    </div>
  ) : (
    <div class="mb-6 rounded border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-900">
      <strong>{companyName}</strong> went into administration
      {administrationDate && (
        <span> on {administrationDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
      )}.
      This page explains how to make a Section 75 claim if you paid by credit card.
    </div>
  )}

  <article class="prose prose-gray max-w-none">
    <Content />
  </article>

  <div class="mt-10 rounded-lg border border-gray-200 bg-gray-50 px-6 py-5">
    <h2 class="text-base font-semibold text-gray-900 mb-2">Ready to claim?</h2>
    <p class="text-sm text-gray-700 mb-4">
      Our claim pack includes a template letter written specifically for administration cases, an evidence checklist, and a step-by-step guide to submitting your claim.
    </p>
    <a href="/claim-pack/" class="btn-primary">
      Get the claim pack — £2.99
    </a>
  </div>

  <p class="mt-6 text-xs text-gray-400">
    Last updated: {updatedAt.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
  </p>
</BaseLayout>
