---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  disclaimer?: boolean;
  noindex?: boolean;
}

const { title, description, disclaimer = false, noindex = false } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{title} | Section 75 Claim Helper</title>
  </head>
  <body class="bg-white text-gray-900 antialiased">

    <header class="border-b border-gray-200">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-sm font-semibold text-gray-900 hover:text-gray-700">
          Section 75 Claim Helper
        </a>
        <nav>
          <ul class="flex gap-5 text-sm text-gray-600">
            <li><a href="/guide/" class="hover:text-gray-900">Guide</a></li>
            <li><a href="/claim-pack/" class="hover:text-gray-900">Claim Pack</a></li>
            <li><a href="/about/" class="hover:text-gray-900">About</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
      {disclaimer && (
        <div class="mb-8 rounded border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
          <strong>Important:</strong> The information on this page is general information only and does not constitute legal advice for your specific circumstances. Every claim depends on its individual facts. If you are unsure about your position, consult a solicitor.
        </div>
      )}
      <slot />
    </main>

    <footer class="mt-16 border-t border-gray-200">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8 text-sm text-gray-500">
        <p>
          Section 75 Claim Helper is an information service, not a claims management company.
          We do not handle claims on your behalf or represent you to your bank.
          <a href="/disclaimer/" class="underline hover:text-gray-700">Full disclaimer and affiliate disclosure.</a>
        </p>
        <p class="mt-3 flex gap-4">
          <a href="/about/" class="hover:text-gray-700">About</a>
          <a href="/disclaimer/" class="hover:text-gray-700">Disclaimer</a>
          <a href="/privacy/" class="hover:text-gray-700">Privacy</a>
          <a href="/contact/" class="hover:text-gray-700">Contact</a>
        </p>
      </div>
    </footer>

  </body>
</html>
